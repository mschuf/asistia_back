# --- Server ---
SERVER_PORT=1001
SERVER_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# --- JWT ---
JWT_SECRET=replace-with-a-random-32+-chars-secret
JWT_EXPIRES_IN=365d

# --- Auth (LDAP only) ---
AUTH_PROVIDER=ldap
# RSA key pair for encrypting login credentials (PEM, use \n for newlines in .env)
AUTH_RSA_PRIVATE_KEY=
AUTH_RSA_PUBLIC_KEY=
AUTH_COOKIE_NAME=asistia_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_MAX_AGE=0
LDAP_URL=ldaps://ldap.example.com:636
LDAP_DOMAIN=example.com
LDAP_BASE_DN=DC=example,DC=com
LDAP_ADMIN=
LDAP_ADMIN_PWD=

# --- GLPI 9.4.2 ---
GLPI_BASE_URL=http://glpi.example.com/apirest.php
GLPI_APP_TOKEN=
GLPI_CATALOG_BOOTSTRAP_LOGIN=
GLPI_CATALOG_BOOTSTRAP_PASSWORD=
GLPI_DEFAULT_ENTITY=0
GLPI_REQUEST_TIMEOUT_MS=15000
GLPI_SESSION_TTL_SECONDS=28800
# false = cuenta API sin perfil técnico (recomendado). true = parche si GLPI sigue auto-asignando asistIA.
GLPI_STRIP_SERVICE_ASSIGNMENT=false
# ID numérico del usuario asistIA en GLPI (ej. 1368). Opcional; solo si GLPI_STRIP_SERVICE_ASSIGNMENT=true.
GLPI_SERVICE_USER_ID=

# --- Cache ---
CACHE_TTL_DEFAULT_SECONDS=600
CACHE_TTL_CATALOG_SECONDS=3600

# --- SMTP (opcional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_AUTH=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=asistIA
SMTP_REJECT_UNAUTHORIZED=true

# --- Attachments ---
ATTACHMENTS_MAX_BYTES=5242880
ATTACHMENTS_ALLOWED_MIME=image/png,image/jpeg,image/webp

# --- IA (scaffold, sin uso en MVP) ---
AI_PROVIDER=
OPENAI_API_KEY=
